<%- include('../partials/site-start', { title, description }) %>
<section class="section-pad hero-page">
  <div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4" data-aos="fade-up">
      <div>
        <span class="eyebrow">Admin Dashboard</span>
        <h1 class="section-title">Operational control center</h1>
        <p class="section-copy mb-0">Manage news, projects, products, inquiries, and investor engagement.</p>
      </div>
      <form method="post" action="/admin/logout">
        <button class="btn btn-outline-light" type="submit">Logout</button>
      </form>
    </div>

    <div class="row g-4">
      <div class="col-md-6 col-xl-3"><div class="dashboard-card"><h3>News</h3><p>Publish updates and featured stories.</p></div></div>
      <div class="col-md-6 col-xl-3"><div class="dashboard-card"><h3>Projects</h3><p>Track plantation and factory milestones.</p></div></div>
      <div class="col-md-6 col-xl-3"><div class="dashboard-card"><h3>Products</h3><p>Manage bamboo product catalog entries.</p></div></div>
      <div class="col-md-6 col-xl-3"><div class="dashboard-card"><h3>Inquiries</h3><p>Review investor and partnership requests.</p></div></div>
    </div>
  </div>
</section>
<%- include('../partials/site-end') %>
