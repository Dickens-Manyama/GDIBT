<%- include('../partials/site-start', { 
  title: 'BambooGuard Campaign', 
  description: 'Securing Our Future Through Green Defense through bamboo restoration, climate action, and community empowerment in Tanzania.' 
}) %>

<section class="section-pad hero-page">
  <div class="container">

    <div class="text-center mb-5" data-aos="fade-up">
      <span class="eyebrow">BambooGuard Campaign</span>

      <h1 class="section-title">
        Securing Our Future Through Green Defense
      </h1>

      <p class="section-copy mx-auto" style="max-width: 820px;">
        "The BambooGuard Campaign is a national land restoration and sustainability initiative 
led in partnership with UNLOCK GROUP LIMITED Tanzania, JWAPANO, and the Tanzania People's Defence Force (TPDF). 
The campaign aims to restore degraded ecosystems, combat climate change, strengthen 
rural economies, and empower communities through large-scale bamboo cultivation and innovation".
      </p>

      <a class="btn btn-gold btn-lg mt-3" href="/contact">
        Partner With Us
      </a>
    </div>

    

    <div class="auth-card mb-5" data-aos="fade-up">
      <span class="eyebrow">Our Vision</span>

      <h2 class="section-title-sm mb-3">
        Building a Greener and More Resilient Tanzania
      </h2>

      <p class="section-copy">
        BambooGuard envisions a future where restored bamboo ecosystems contribute to 
        climate resilience, biodiversity conservation, and sustainable economic growth. 
        Through environmental stewardship and innovation, the initiative strengthens the 
        connection between communities, sustainability, and national development.
      </p>
    </div>

    <div class="row g-4 mb-5">

      <div class="col-lg-6" data-aos="fade-right">
        <div class="auth-card h-100">
          <span class="eyebrow">Environmental Impact</span>

          <ul class="list-unstyled mt-3">
            <li class="mb-3">✔ Land restoration and ecosystem recovery</li>
            <li class="mb-3">✔ Carbon sequestration and climate action</li>
            <li class="mb-3">✔ Soil erosion prevention</li>
            <li class="mb-3">✔ Biodiversity conservation</li>
            <li class="mb-3">✔ Sustainable bamboo forestry</li>
          </ul>
        </div>
      </div>

      <div class="col-lg-6" data-aos="fade-left">
        <div class="auth-card h-100">
          <span class="eyebrow">Community Impact</span>

          <ul class="list-unstyled mt-3">
            <li class="mb-3">✔ Rural employment opportunities</li>
            <li class="mb-3">✔ Youth and women empowerment</li>
            <li class="mb-3">✔ Bamboo innovation centers</li>
            <li class="mb-3">✔ Skills training and entrepreneurship</li>
            <li class="mb-3">✔ Sustainable income generation</li>
          </ul>
        </div>
      </div>

    </div>

    <div class="auth-card text-center" data-aos="zoom-in">
      <span class="eyebrow">Join The Movement</span>

      <h2 class="section-title-sm mb-3">
        Strength in Restoration, Security in Sustainability
      </h2>

      <p class="section-copy mx-auto" style="max-width: 760px;">
        Together, we can restore degraded land, create sustainable livelihoods, 
        and position Tanzania as a global leader in environmental restoration 
        and green innovation through bamboo ecosystems.
      </p>

      <a class="btn btn-outline-light btn-lg mt-3" href="/contact">
        Contact Us
      </a>
    </div>

  </div>
</section>

<%- include('../partials/site-end') %>