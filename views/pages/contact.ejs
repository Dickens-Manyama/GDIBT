<%- include('../partials/site-start', { title: 'Contact | GDBIT', description: 'Send partnership, investor, and media inquiries to the Green Defence Bamboo Initiative Tanzania team.' }) %>
<section class="section-pad hero-page">
  <div class="container">
    <div class="row g-4 align-items-start">
      <div class="col-lg-5" data-aos="fade-right">
        <span class="eyebrow">Contact and Collaboration</span>
        <h1 class="section-title">Start a partnership conversation</h1>
        <p class="section-copy">For investors, institutions, communities, and media partners seeking a structured engagement with the GDBIT platform.</p>
        <% if (sent) { %>
          <div class="alert alert-success">Your inquiry has been received. The team will respond shortly.</div>
        <% } %>
        <div class="glass-card p-4 mt-4">
          <p class="mb-2"><strong>UNLOCK GROUP LIMITED Tanzania</strong></p>
          <p class="mb-2"><strong>JWAPANO Bamboo Tanzania</strong></p>
          <p class="mb-2 mb-0 text-white-50">Postal: Ruvu Street, Mikocheni · P.O. Box 31618 · Dar es Salaam, Tanzania</p>
        </div>
      </div>
      <div class="col-lg-7" data-aos="fade-left">
        <div class="glass-card p-4">
          <h2 class="section-title h3">General contact form</h2>
          <form method="post" action="/contact" class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Full name</label>
              <input class="form-control form-control-lg" type="text" name="name" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Email address</label>
              <input class="form-control form-control-lg" type="email" name="email" required />
            </div>
            <div class="col-12">
              <label class="form-label">Subject</label>
              <input class="form-control form-control-lg" type="text" name="subject" value="General partnership inquiry" required />
            </div>
            <div class="col-12">
              <label class="form-label">Message</label>
              <textarea class="form-control" name="message" rows="5" required></textarea>
            </div>
            <div class="col-12 d-flex flex-wrap gap-3">
              <button class="btn btn-gold btn-lg" type="submit">Send inquiry</button>
              <a class="btn btn-outline-light btn-lg" href="/investment">Investor presentation</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="row g-4 mt-2">
      <div class="col-lg-4" data-aos="fade-up">
        <div class="glass-card p-4 h-100">
          <h2 class="h3">Investor inquiry form</h2>
          <form method="post" action="/contact" class="row g-3">
            <div class="col-12"><input class="form-control" type="text" name="name" placeholder="Full name" required /></div>
            <div class="col-12"><input class="form-control" type="email" name="email" placeholder="Email address" required /></div>
            <div class="col-12"><input class="form-control" type="text" name="subject" value="Investor inquiry" required /></div>
            <div class="col-12"><textarea class="form-control" name="message" rows="4" placeholder="Tell us about your investment interest" required></textarea></div>
            <div class="col-12"><button class="btn btn-outline-light w-100" type="submit">Request investor briefing</button></div>
          </form>
        </div>
      </div>
      <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
        <div class="glass-card p-4 h-100">
          <h2 class="h3">Partnership application form</h2>
          <form method="post" action="/contact" class="row g-3">
            <div class="col-12"><input class="form-control" type="text" name="name" placeholder="Organization name" required /></div>
            <div class="col-12"><input class="form-control" type="email" name="email" placeholder="Official email" required /></div>
            <div class="col-12"><input class="form-control" type="text" name="subject" value="Partnership application" required /></div>
            <div class="col-12"><textarea class="form-control" name="message" rows="4" placeholder="Describe your partnership interest" required></textarea></div>
            <div class="col-12"><button class="btn btn-outline-light w-100" type="submit">Apply for partnership</button></div>
          </form>
        </div>
      </div>
      <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
        <div class="glass-card p-4 h-100">
          <h2 class="h3">Offices</h2>
          <p><strong>Dar es Salaam</strong><br />Partnership engagement, investor meetings, and institutional coordination.</p>
          <p class="mb-0"><strong>Lindi operations</strong><br />Factory coordination, field activity, and bamboo processing leadership.</p>
        </div>
      </div>
    </div>

    <div class="glass-card p-3 p-md-4 mt-4" data-aos="fade-up">
      <iframe title="GDBIT map" src="https://www.google.com/maps?q=Dar%20es%20Salaam%20Tanzania&output=embed" width="100%" height="360" style="border:0; border-radius: 1.25rem;" loading="lazy"></iframe>
    </div>
  </div>
</section>
<%- include('../partials/site-end') %>
