<%- include('../partials/site-start', { title: title, description: 'Our team at GDBIT' }) %>
<section class="section-pad">
  <div class="container">
    <div class="section-heading" data-aos="fade-up">
      <span class="eyebrow">Our People</span>
      <h1 class="section-title">Meet the teams behind GDBIT</h1>
    </div>

    <% teams.forEach(function(teamBlock){ %>
      <div class="company-block mt-4" data-aos="fade-up">
        <div class="d-flex align-items-center gap-3 mb-3">
          <% if (teamBlock.logo) { %>
            <img src="<%= teamBlock.logo %>" alt="<%= teamBlock.company %> logo" style="height:48px; object-fit:contain;"/>
          <% } %>
          <h3 class="mb-0 text-capitalize"><%= teamBlock.company %> team</h3>
        </div>
        <div class="row g-3">
          <% if (teamBlock.members && teamBlock.members.length) { %>
            <% teamBlock.members.forEach(function(member){ %>
              <div class="col-6 col-md-4 col-lg-3">
                <div class="team-card glass-card p-3 h-100 text-center">
                  <% if (member.image) { %>
                    <img src="<%= member.image %>" alt="<%= member.displayName || member.name %>" class="team-photo mb-2" data-name="<%= (member.displayName || member.name).toString().replace(/\"/g, '&quot;') %>" data-bio="<%= (member.bio||'').toString().replace(/\"/g, '&quot;') %>" />
                  <% } %>
                  <h5 class="mb-1"><%= member.displayName %></h5>
                  <% if (teamBlock.company === 'unlock' && member.displayName) { %>
                    <% if (member.displayName.toLowerCase().includes('baraka')) { %>
                      <p class="small text-white-50">Baraka Peneza is an experienced professional with strong expertise in project management, product innovation, finance, research, and business development. He has successfully contributed to the growth and strategic direction of multiple projects and initiatives through his leadership, analytical skills, and innovation-driven approach.</p>
                    <% } else if (member.displayName.toLowerCase().includes('frank')) { %>
                      <p class="small text-white-50">Frank Ephraim Kamina is an expert in export and port operations with over ten years of experience in the maritime industry. His extensive knowledge in logistics, shipping processes, and international trade operations has played a significant role in supporting efficient business and operational management.</p>
                    <% } else if (member.displayName.toLowerCase().includes('mohamed')) { %>
                      <p class="small text-white-50">Mohamed Lawrence Lwanji is a business development professional with more than six years of experience in tax administration and sales. He specializes in business growth strategies, client relations, and revenue development, contributing valuable expertise to the company’s commercial operations and expansion initiatives.</p>
                    <% } %>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-12"><p class="text-white-50">Team information coming soon.</p></div>
          <% } %>
        </div>
      </div>
    <% }) %>

  </div>
</section>
<!-- Person modal -->
<div class="modal fade" id="personModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-md">
    <div class="modal-content glass-card p-3">
      <div class="modal-body">
        <div class="d-flex gap-3 align-items-start">
          <img id="modalPhoto" src="" alt="" style="width:120px; height:120px; object-fit:cover; border-radius:.6rem;" />
          <div>
            <h4 id="modalName" class="mb-1"></h4>
            <p id="modalBio" class="small" style="color:var(--muted);"></p>
          </div>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/site-end') %>
