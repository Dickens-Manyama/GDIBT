<%- include('../partials/site-start', { title: 'Product Gallery', description: 'Gallery of Military, Public, and Commercial Bamboo Products.' }) %>
<section class="section-pad">
  <div class="container">
    <div class="section-heading" data-aos="fade-up">
      <span class="eyebrow">Product Gallery</span>
      <h1 class="section-title">Our Bamboo Product Gallery</h1>
      <p class="section-copy">Browse our range of military, public, and commercial bamboo products below.</p>
    </div>
    <div class="row g-4" id="product-galleries">
      <div class="col-12">
        <h2 class="mb-3">Military Products Gallery</h2>
        <div class="row g-2">
          <% ['bamboo packaging.jpg','camp structures.jpg','military storage unit.jpg','packagin 2.png','roofing sheets.jpg'].forEach(function(img){ %>
            <div class="col-6 col-md-4 col-lg-3">
              <img src="/images/Military%20Products%20to%20be%20Produced/<%= img %>" alt="Military Product" class="img-fluid rounded shadow-sm" />
            </div>
          <% }) %>
        </div>
      </div>
      <div class="col-12 mt-4">
        <h2 class="mb-3">Public & Commercial Products Gallery</h2>
        <div class="row g-2">
          <% ['charcoal bricks.jpg','cottonbuds.jpeg','decorative product.jpg','flooring 1.jpg','flooring.jpg','furniture 4.jpg','home tools.jpeg','household product.jpg','products.jpeg','schooldesks and office.jpg','sticks.jpeg','toothpick.jpeg'].forEach(function(img){ %>
            <div class="col-6 col-md-4 col-lg-3">
              <img src="/images/Public%20and%20Commercial%20Products/<%= img %>" alt="Public Product" class="img-fluid rounded shadow-sm" />
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/site-end') %>